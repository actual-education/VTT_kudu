# API Configuration
USE_MOCKS=true
DATABASE_URL=sqlite:///./avce.db
SECRET_KEY=change-me-in-production

# App login protection (set to enable password auth)
AUTH_PASSWORD=change-me-before-production
AUTH_COOKIE_NAME=avce_auth
AUTH_SESSION_TTL_HOURS=24
AUTH_COOKIE_SECURE=false

# YouTube Data API
YOUTUBE_API_KEY=
YT_DLP_BINARY=yt-dlp
FFMPEG_BINARY=ffmpeg
VIDEO_CACHE_DIR=/tmp/avce_videos
FRAME_OUTPUT_DIR=/tmp/avce_frames

# OCR
TESSERACT_CMD=tesseract

# OpenAI (optional if using Azure OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Azure OpenAI (optional if using OpenAI)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Google OAuth (for YouTube upload)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_OAUTH_CLIENT_SECRETS_FILE=
YOUTUBE_OAUTH_TOKEN_FILE=

# If true, model failures (bad key, bad deployment, API errors) fail the job instead of falling back.
REQUIRE_MODEL_SUCCESS=false

# AI cost estimate inputs (USD per 1M tokens). Set to your Azure pricing.
AI_COST_INPUT_PER_1M_TOKENS=0
AI_COST_OUTPUT_PER_1M_TOKENS=0

# Segment merge tuning (reduce duplicate/static visual segments)
SEGMENT_MERGE_MAX_GAP_SECONDS=1.5
SEGMENT_MERGE_OCR_SIMILARITY_THRESHOLD=0.85
SEGMENT_MERGE_DESCRIPTION_SIMILARITY_THRESHOLD=0.75
